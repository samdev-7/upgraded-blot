# Python caches
__pycache__/
*.pyc

# Arduino / compiled firmware artifacts
firmware/*.o
firmware/build/

# Host-test build artifacts (sources are tracked; only generated files are ignored)
firmware/test/*.o
firmware/test/mocks/*.o
firmware/test/mocks/**/*.o
firmware/test/run_tests

# UI save-dialog defaults (land in ui/ when the user keeps the default path)
ui/out.*
ui/preview.png

# Personal / test images that tend to land in the tools folder
firmware/tools/*.jpg
firmware/tools/*.jpeg
firmware/tools/*.png
